{
  "name": "@pruddiman/fleet",
  "version": "0.1.6",
  "description": "A TypeScript CLI tool for managing deployments",
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PatrickRuddiman/Fleet.git"
  },
  "license": "MIT",
  "keywords": [
    "cli",
    "deploy",
    "docker",
    "docker-compose",
    "caddy",
    "reverse-proxy",
    "fleet"
  ],
  "homepage": "https://github.com/PatrickRuddiman/Fleet#readme",
  "bin": {
    "fleet": "bin/fleet"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "build:binaries": "pkg . --out-path releases"
  },
  "dependencies": {
    "@infisical/sdk": "^5.0.0",
    "commander": "^14.0.3",
    "node-ssh": "^13.2.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@yao-pkg/pkg": "^5.15.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pkg": {
    "entry": "bin/fleet",
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-macos-arm64"
    ],
    "assets": [
      "dist/**/*"
    ],
    "outputPath": "releases"
  }
}
